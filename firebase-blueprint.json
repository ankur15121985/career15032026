{
  "entities": {
    "Career": {
      "title": "Career",
      "description": "A career path or stream in the hierarchy.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["root", "branch", "leaf"] },
        "parent_id": { "type": "string" },
        "duration": { "type": "string" },
        "job_roles": { "type": "string" },
        "is_leaf": { "type": "boolean" }
      },
      "required": ["name", "type"]
    },
    "College": {
      "title": "College",
      "description": "A college offering a specific career path.",
      "type": "object",
      "properties": {
        "career_id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "fees": { "type": "string" },
        "duration": { "type": "string" },
        "ranking": { "type": "string" },
        "specialization": { "type": "string" },
        "website": { "type": "string" }
      },
      "required": ["career_id", "name"]
    },
    "QuizSubmission": {
      "title": "Quiz Submission",
      "description": "A user's quiz results and contact info.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "answers": { "type": "array", "items": { "type": "object" } },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "answers", "created_at"]
    },
    "Question": {
      "title": "Question",
      "description": "A quiz question.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["AQ", "IQ"] },
        "category": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correct_answer": { "type": "string" }
      },
      "required": ["text", "type", "category", "options", "correct_answer"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A scheduled counseling session.",
      "type": "object",
      "properties": {
        "submission_id": { "type": "string" },
        "consultant_name": { "type": "string" },
        "appointment_time": { "type": "string", "format": "date-time" },
        "user_name": { "type": "string" },
        "user_email": { "type": "string", "format": "email" },
        "user_phone": { "type": "string" },
        "aq_score": { "type": "integer" },
        "iq_score": { "type": "integer" },
        "top_recommendation": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["consultant_name", "appointment_time", "user_name", "user_email", "created_at"]
    },
    "AdminSetting": {
      "title": "Admin Setting",
      "description": "Configuration key-value pairs.",
      "type": "object",
      "properties": {
        "value": { "type": "string" }
      },
      "required": ["value"]
    },
    "IPLog": {
      "title": "IP Log",
      "description": "Visitor IP tracking.",
      "type": "object",
      "properties": {
        "ip_address": { "type": "string" },
        "visited_at": { "type": "string", "format": "date-time" }
      },
      "required": ["ip_address", "visited_at"]
    }
  },
  "firestore": {
    "careers": { "schema": "Career", "description": "Career hierarchy data" },
    "colleges": { "schema": "College", "description": "College listings" },
    "quiz_submissions": { "schema": "QuizSubmission", "description": "User quiz results" },
    "questions": { "schema": "Question", "description": "Quiz questions" },
    "appointments": { "schema": "Appointment", "description": "Counseling appointments" },
    "admin_settings": { "schema": "AdminSetting", "description": "App configuration" },
    "ip_logs": { "schema": "IPLog", "description": "Visitor tracking" }
  }
}
