{
  "entities": {
    "career": {
      "title": "Career",
      "description": "A career path or branch in the career map.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the career." },
        "name": { "type": "string", "description": "Name of the career." },
        "type": { "type": "string", "enum": ["root", "branch", "leaf"], "description": "Type of the career node." },
        "parent_id": { "type": "string", "description": "ID of the parent career node." },
        "duration": { "type": "string", "description": "Duration of the course/career path." },
        "job_roles": { "type": "string", "description": "Typical job roles for this career." },
        "is_leaf": { "type": "boolean", "description": "Whether this is a terminal node in the graph." }
      },
      "required": ["id", "name", "type"]
    },
    "college": {
      "title": "College",
      "description": "An institution offering a specific career path.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the college entry." },
        "career_id": { "type": "string", "description": "ID of the career this college is linked to." },
        "name": { "type": "string", "description": "Name of the college." },
        "location": { "type": "string", "description": "Location of the college." },
        "fees": { "type": "string", "description": "Fees for the course." },
        "duration": { "type": "string", "description": "Duration of the course at this college." },
        "ranking": { "type": "string", "description": "Ranking or status of the college." },
        "specialization": { "type": "string", "description": "Specialization offered." },
        "website": { "type": "string", "description": "Official website URL." }
      },
      "required": ["career_id", "name"]
    }
  },
  "firestore": {
    "/careers/{careerId}": {
      "schema": "career",
      "description": "Collection of career paths."
    },
    "/colleges/{collegeId}": {
      "schema": "college",
      "description": "Collection of colleges."
    }
  }
}
