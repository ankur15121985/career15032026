rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: careers
    // Fields: name, type, parent_id, duration, job_roles, is_leaf
    //
    // Collection: colleges
    // Fields: career_id, name, location, fees, duration, ranking, specialization, website
    //
    // Collection: quiz_submissions
    // Fields: name, email, phone, answers, created_at
    //
    // Collection: questions
    // Fields: text, type, category, options, correct_answer
    //
    // Collection: appointments
    // Fields: submission_id, consultant_name, appointment_time, user_name, user_email, user_phone, aq_score, iq_score, top_recommendation, created_at
    //
    // Collection: admin_settings
    // Fields: value
    //
    // Collection: ip_logs
    // Fields: ip_address, visited_at
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ankur15121985@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /careers/{careerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /colleges/{collegeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quiz_submissions/{submissionId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ip_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
  }
}
