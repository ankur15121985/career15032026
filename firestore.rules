rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: careers
    // Document ID: career_id (string)
    // Fields:
    //   - name: string (required)
    //   - type: string (required, enum: ['root', 'branch', 'leaf'])
    //   - parent_id: string | null (optional)
    //   - duration: string | null (optional)
    //   - job_roles: string | null (optional)
    //   - is_leaf: bool (required)
    //
    // Collection: colleges
    // Document ID: auto-generated
    // Fields:
    //   - career_id: string (required)
    //   - name: string (required)
    //   - location: string (optional)
    //   - fees: string (optional)
    //   - duration: string (optional)
    //   - ranking: string (optional)
    //   - specialization: string (optional)
    //   - website: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "ankur15121985@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidCareer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.type in ['root', 'branch', 'leaf'] &&
             (data.parent_id == null || data.parent_id is string) &&
             (data.duration == null || data.duration is string) &&
             (data.job_roles == null || data.job_roles is string) &&
             data.is_leaf is bool;
    }

    function isValidCollege(data) {
      return data.career_id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (data.location == null || data.location is string) &&
             (data.fees == null || data.fees is string) &&
             (data.duration == null || data.duration is string) &&
             (data.ranking == null || data.ranking is string) &&
             (data.specialization == null || data.specialization is string) &&
             (data.website == null || data.website is string);
    }

    // Rules
    match /careers/{careerId} {
      allow read: if true; // Publicly readable for the career map
      allow write: if isAdmin() && isValidCareer(request.resource.data);
    }

    match /colleges/{collegeId} {
      allow read: if true; // Publicly readable for college info
      allow write: if isAdmin() && isValidCollege(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
